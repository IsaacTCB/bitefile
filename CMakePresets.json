{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "generator": "Ninja",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "static_debug",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_SHARED_LIBS": "OFF"
            },
            "binaryDir": "build/debug"
        },
        {
            "name": "static_release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "binaryDir": "build/release"
        },
        {
            "name": "shared_debug",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_SHARED_LIBS": "OFF"
            },
            "binaryDir": "build/debug"
        },
        {
            "name": "shared_release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_SHARED_LIBS": "ON"
            },
            "binaryDir": "build/release"
        }
    ],
    "buildPresets": [
        {
            "name": "static_debug",
            "configurePreset": "static_debug",
            "configuration": "Debug"
        },
        {
            "name": "static_release",
            "configurePreset": "static_release",
            "configuration": "Release"
        },
        {
            "name": "shared_debug",
            "configurePreset": "shared_debug",
            "configuration": "Debug"
        },
        {
            "name": "shared_release",
            "configurePreset": "shared_release",
            "configuration": "Release"
        }
    ]
}
